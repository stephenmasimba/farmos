{
  "name": "farmos/backend",
  "description": "FarmOS Backend API - Pure PHP",
  "type": "project",
  "require": {
    "php": "^8.0",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-mbstring": "*",
    "firebase/php-jwt": "^6.4",
    "guzzlehttp/guzzle": "^7.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "squizlabs/php_codesniffer": "^3.7",
    "phpstan/phpstan": "^1.9",
    "vimeo/psalm": "^5.0"
  },
  "autoload": {
    "psr-4": {
      "FarmOS\\": "src/",
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs --standard=PSR12 src/",
    "type-check": "phpstan analyse src/",
    "serve": "php -S 127.0.0.1:8000 -t public/"
  },
  "config": {
    "allow-plugins": {
      "psr-0": true
    }
  }
}
