{
  "name": "farmos/backend",
  "description": "FarmOS Backend API - Pure PHP",
  "type": "project",
  "require": {
    "php": "^7.4",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-mbstring": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "squizlabs/php_codesniffer": "^3.7",
    "phpstan/phpstan": "^1.9"
  },
  "autoload": {
    "psr-4": {
      "FarmOS\\": "src/",
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs -n --standard=PSR12 --exclude=PSR1.Classes.ClassDeclaration src/",
    "type-check": "phpstan analyse src/ --memory-limit=1G",
    "serve": "php -S 127.0.0.1:8001 -t public/"
  },
  "config": {
    "allow-plugins": {
      "psr-0": true
    }
  }
}
