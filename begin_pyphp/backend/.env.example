# ============================================================================
# FarmOS Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env file to version control!
# ============================================================================

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
NODE_ENV=development
# Options: development, staging, production
# Use 'production' in production environments for additional security checks

APP_NAME=FarmOS
APP_VERSION=1.0.0
DEBUG=false

# ============================================================================
# SECURITY - CRITICAL: Change These in Production!
# ============================================================================

# JWT Configuration
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_SECRET_MIN_32_CHARS
# Token expiration in seconds (3600 = 1 hour)
JWT_EXPIRATION_SECONDS=3600
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Key for internal/third-party integrations
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_SECRET
# API Key rotation interval in days (0 = disabled)
API_KEY_ROTATION_DAYS=90

# Secret key for session encryption
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_STRONG_RANDOM_SECRET_MIN_32_CHARS

# Allowed CORS origins (comma-separated for production)
CORS_ORIGIN=http://localhost,http://localhost:3000,http://localhost:8080
# For production, specify exact origins:
# CORS_ORIGIN=https://yourdomain.com,https://api.yourdomain.com

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# MySQL Database
DB_DRIVER=mysql+pymysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=begin_masimba_farm
# Full connection string (generated from above)
DATABASE_URL=mysql+pymysql://root:@localhost:3306/begin_masimba_farm

# Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Redis for caching and rate limiting
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Full Redis URL
REDIS_URL=redis://localhost:6379/0

# Cache TTL in seconds (1 hour = 3600)
CACHE_TTL=3600

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Log format: json, text
LOG_FORMAT=json
# Log file directory (empty = stdout only)
LOG_DIR=/var/log/farmos
# Keep logs for X days
LOG_RETENTION_DAYS=30

# ============================================================================
# EMAIL CONFIGURATION (For notifications)
# ============================================================================

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@farmos.local
SMTP_USE_TLS=true

# ============================================================================
# AWS/CLOUD CONFIGURATION (Optional)
# ============================================================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=farmos-data

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit for authentication endpoints (requests per minute)
RATE_LIMIT_AUTH_REQUESTS=5
# Rate limit for general API endpoints (requests per minute)
RATE_LIMIT_API_REQUESTS=100
# Rate limit for file upload endpoints (requests per hour)
RATE_LIMIT_UPLOAD_REQUESTS=50

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================

# Max file upload size in bytes (100MB = 104857600)
MAX_UPLOAD_SIZE=104857600
# Allowed file extensions (comma-separated)
ALLOWED_FILE_EXTENSIONS=pdf,jpg,jpeg,png,xlsx,csv,doc,docx
# Upload directory
UPLOAD_DIR=./uploads

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================

# Backup schedule: daily, weekly, monthly
BACKUP_SCHEDULE=daily
# Backup retention in days
BACKUP_RETENTION_DAYS=30
# Backup directory
BACKUP_DIR=./backups

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Weather API (e.g., OpenWeatherMap)
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Payment Gateway (Stripe, PayPal, etc.)
PAYMENT_PROVIDER=stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# SMS Service (e.g., Twilio)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================================================
# FEATURE FLAGS
# ============================================================================

FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_SMS_NOTIFICATIONS=false
FEATURE_IOT_INTEGRATION=true
FEATURE_BLOCKCHAIN=false
FEATURE_ADVANCED_ANALYTICS=true

# ============================================================================
# DEVELOPMENT/DEBUG FLAGS
# ============================================================================

# Enable request/response logging (verbose)
LOG_REQUESTS=false
# Enable SQL query logging
LOG_SQL=false
# Auto-reload on file changes (dev only)
AUTO_RELOAD=true
