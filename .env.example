# ============================================================================
# FarmOS Environment Configuration
# ============================================================================
# Copy this file to .env and configure for your environment
# ============================================================================

# ============================================================================
# Application Settings
# ============================================================================
APP_ENV=production
APP_NAME=FarmOS
APP_URL=http://localhost:8000
LOG_DIR=/var/log/farmos
LOG_FORMAT=json

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=mysql:host=mysql;port=3306;dbname=farmos
DB_HOST=mysql
DB_PORT=3306
DB_NAME=farmos
DB_USER=farmos_user
DB_PASSWORD=farmos_password
DB_ROOT_PASSWORD=root_password

# ============================================================================
# Security & Authentication
# ============================================================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=3600
BCRYPT_COST=12

# ============================================================================
# CORS & API Settings
# ============================================================================
CORS_ORIGIN=http://localhost:3000
API_URL=http://localhost:8000
API_PORT=8000

# ============================================================================
# Redis Configuration (Caching & Rate Limiting)
# ============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ============================================================================
# Rate Limiting
# ============================================================================
# Auth endpoints: requests per minute
RATE_LIMIT_AUTH=5

# API endpoints: requests per minute
RATE_LIMIT_API=100

# Upload endpoints: requests per hour
RATE_LIMIT_UPLOAD=50

# ============================================================================
# Email Configuration (Optional - for notifications)
# ============================================================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@farmos.local
MAIL_FROM_NAME=FarmOS

# ============================================================================
# Frontend Configuration
# ============================================================================
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000
NODE_ENV=production

# ============================================================================
# AWS S3 Configuration (Optional - for file uploads)
# ============================================================================
AWS_KEY=
AWS_SECRET=
AWS_REGION=us-east-1
AWS_BUCKET=farmos-uploads

# ============================================================================
# Weather API Configuration (Optional - for weather integration)
# ============================================================================
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# ============================================================================
# Monitoring & Logging
# ============================================================================
SENTRY_DSN=
LOG_LEVEL=info
ENABLE_PROFILING=false

# ============================================================================
# Development Settings (only use in development)
# ============================================================================
DEBUG=false
DISPLAY_ERRORS=false
ERROR_REPORTING=0
